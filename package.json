{
  "name": "@syllang/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "start": "next start",
    "prepare": "simple-git-hooks",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "check": "pnpm typecheck && pnpm build",
    "check:mermaid": "node scripts/check-mermaid.mjs",
    "check:readtime": "node scripts/check-readtime.mjs",
    "check:links": "node scripts/check-links.mjs"
  },
  "simple-git-hooks": {
    "commit-msg": "./.githooks/commit-msg"
  },
  "dependencies": {
    "@fumadocs/language": "^0.0.1",
    "@orama/tokenizers": "^3.1.18",
    "beautiful-mermaid": "^1.1.3",
    "fumadocs-core": "^16.9.0",
    "fumadocs-mdx": "^15.0.7",
    "fumadocs-ui": "^16.9.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.0.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.14",
    "reading-time": "^1.5.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.22.0"
}
